# =============================================================================
# .deploy.env — Variables d'environnement pour le DEPLOY
# =============================================================================
# Fichier GITIGNORÉ contenant les infos sensibles du VPS.
# Créer depuis ce template avec :
#   cp .deploy.env.example .deploy.env
#   chmod 600 .deploy.env
#   nano .deploy.env  # éditer les valeurs
# =============================================================================

# VPS cible
VPS_HOST=ubuntu@VOTRE_IP
VPS_SSH_KEY=~/.ssh/VOTRE_CLE_DEPLOY

# Path sur le VPS
VPS_DEPLOY_PATH=/opt/lyonflow

# Branche Git à déployer (sprint actif)
DEPLOY_BRANCH=main

# =============================================================================
# Backup offsite (Sprint VPS-2 — règle stricte : JAMAIS de backup local)
# =============================================================================
# Choix A (recommandé) : rclone vers Google Drive dédié
#   - Configurer rclone : rclone config (créer un remote "gdrive:")
#   - Folder Google Drive ID : 1TO-4OwTlFr5s3v9-apu1MbA5jZ-yfNDR (LyooFlow)
#   - Activer le backup : décommenter la ligne ci-dessous
#GDRIVE_BACKUP_DEST=gdrive:backups/lyonflow
#
# Choix B : SSH vers serveur distant (rsync over SSH)
#   - Format : user@host:/chemin/distant
#   - Le serveur doit avoir sshd + auth key configurée
#OFFSITE_SSH=user@backup.example.com:~/lyonflow
#
# Choix C (optionnel) : chiffrement GPG avant envoi (recommandé pour cloud)
#   - Générer la clé : gpg --gen-key
#   - Format : 0xLONGKEYID (64 hex chars)
#GPG_RECIPIENT=0x0000000000000000000000000000000000000000
