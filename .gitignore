# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml
.tox/
.nox/

# mypy
.mypy_cache/

# ruff
.ruff_cache/

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Streamlit
.streamlit/secrets.toml

# Airflow
airflow.db
airflow.cfg

# Docker
docker-data/
postgres-data/
minio-data/

# Backups
# Regle : JAMAIS de backup persistant sur le VPS ni dans le repo.
# Tous les backups vont offsite via scripts/backup-offsite.sh.
# Mais on ignore le dossier entier par securite (le dump 2.9 Go local doit
# aussi etre protege contre un git add accidentel).
backups/
backups/*.sql
backups/*.dump
backups/*.dump.gz
backups/*.dump.gz.gpg
backups/*.tar.gz

# Models (gros fichiers)
models/*.pt
models/*.pkl
models/*.joblib

# Uploads
uploads/

# Deploy config (info VPS sensible)
.deploy.env

# Env
.env
.env.local
.env.production

# Secrets
secrets/
*.pem
*.key

# Generated docs
docs/_build/
site/

# docs/ complet (RNCP 38777 : pas versionné, conservable local pour traçabilité)
# Sorti du tracking git Sprint 23 (2026-07-23) — les .md restent sur disque,
# ne sont plus poussés sur GitHub. Voir archive/README.md pour l'historique.
docs/

# Local orchestration plans
.mavis/
.claude/

# LLM / coding assistant tools (defensive — couvre les outils qu'on utilise
# + ceux qu'on pourrait adopter). Sans cette section, certains outils créent
# des caches qu'on voit revenir dans le file browser même s'ils sont gitignored.
.opencode/          # opencode (LLM)
.aider*             # aider
.aider.chat.history
.continue/          # Continue.dev
.cody/              # Sourcegraph Cody
.cursor/            # Cursor
.cursorignore
.windsurf/          # Windsurf
.crush/             # Crush
.roo/               # Roo Code
.copilot/           # GitHub Copilot workspace
.cline/             # Cline
.kiro/              # Kiro

# Mac binary libraries (defensive — émises par certains outils Mac)
*.dylib

# Mémoire projet assistant IA (notes internes, pas destinées au repo public)
CLAUDE.md

# TLS certs (generated, never committed)
nginx/certs/*.pem

# Audit pipeline data (artefacts générés, pas versionnés — RNCP 38777)
# Le script générateur scripts/audit/generate_audit_doc.py reste en local
# (non commité) car c'est un outil one-shot, et les .docx produits sont
# des livrables à archiver hors Git (Google Drive, etc.).
# Note : les SPEC_*.md (Sprint 16, Evidently) restent versionnés — ce sont
# des inputs partagés, pas des artefacts générés.
scripts/audit/
docs/AUDIT_*.docx

# Soutenance (slides HTML, pas du code) — soutenance-bloc4.html (enraciné) ignoré, présentation/ versionné
presentation.html

# Scripts scratch/debug ponctuels (vérifications ad-hoc pendant une session,
# jamais destinés à être rejoués ou committés — cf. archive/scripts/ pour
# les codemods one-off qui, eux, ont une valeur de traçabilité).
scripts/scratch_*
scripts/*_scratch.*
scripts/sql/scratch_*
scripts/sql/check_*.sql
