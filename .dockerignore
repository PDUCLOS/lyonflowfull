# =============================================================================
# LyonFlowFull — .dockerignore
# =============================================================================
# Fichiers exclus du contexte Docker (performance build)
# =============================================================================

# Git
.git/
.gitignore
.github/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.coverage.*

# Virtual envs
.venv/
venv/
env/

# Tests (non embarqués en prod)
tests/

# IDEs
.vscode/
.idea/
.opencode/
*.swp
*.swo

# Node (jamais utilisé en runtime, juste pour tooling local)
node_modules/

# OS
.DS_Store
Thumbs.db

# Docs
docs/
*.md
LICENSE

# Backups
backups/

# Modèles ML (gros, montés via volume)
models/

# Data (gros, monté via volume)
data/
uploads/

# Logs
logs/
*.log

# Env
.env
.env.local
.env.example
!deploy/init-db.sql
