# =============================================================================
# LyonFlowFull — Variables d'environnement
# =============================================================================
# Copier ce fichier en `.env` et remplir toutes les valeurs.
# Generer les secrets forts (production) :
#   POSTGRES_PASSWORD=$(openssl rand -base64 24)
#   AIRFLOW_FERNET_KEY=$(python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())')
#   AIRFLOW_SECRET_KEY=$(openssl rand -base64 32)
#   AIRFLOW_ADMIN_PASSWORD=$(openssl rand -base64 16)
#   LYONFLOW_API_KEY=$(openssl rand -base64 32)
#   JWT_SECRET_KEY=$(openssl rand -base64 32)
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=false

# Politique zero mock (Sprint 8, 2026-06-12)
# -----------------------------------------------------------------------------
# Toujours "0". Le mode demo a ete supprime. Si la DB est indisponible,
# les widgets levent DashboardDataError et affichent st.error().
LYONFLOW_DEMO_MODE=0

# -----------------------------------------------------------------------------
# Affichage aide démo (Sprint P1.3, 2026-06-14)
# -----------------------------------------------------------------------------
# Sprint P1.3 — AUDIT_INTEGRATION_LIVE.md § 2.3.1.
# "1" (défaut, dev local) : affiche l'expander "Aide démo" avec le mot de
#                            passe demo2026 en clair (pour faciliter les tests
#                            Jedha / dev local).
# "0" (prod VPS) : masque l'aide démo — aucun mot de passe n'apparait dans
#                   l'UI. Sécurité : sans ce flag à 0 en prod, n'importe qui
#                   peut se connecter en admin.
# Le check-deploy-env.sh doit valider cette valeur avant chaque déploiement.
LYONFLOW_DEMO_AUTH_HELPER_VISIBLE=0

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=lyonflow
POSTGRES_PASSWORD=<REMPLACER_PAR_MOT_DE_PASSE_FORT>
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lyonflow
# Sous-DBs (créées automatiquement par les init scripts Airflow/MLflow)
POSTGRES_AIRFLOW_DB=airflow
POSTGRES_MLFLOW_DB=mlflow

# -----------------------------------------------------------------------------
# MinIO (optionnel — Google Drive est préféré)
# -----------------------------------------------------------------------------
MINIO_ENABLED=false
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=lyonflow
MINIO_ROOT_PASSWORD=<REMPLACER_SI_MINIO_ENABLED>
MINIO_BUCKET_BRONZE=lyonflow-bronze
MINIO_BUCKET_GOLD=lyonflow-gold

# -----------------------------------------------------------------------------
# Google Drive (PRIMAIRE pour artifacts + file sharing)
# -----------------------------------------------------------------------------
# Setup :
#   1. Projet GCP + Drive API activée
#   2. OAuth 2.0 Client ID (Desktop) → gdrive_credentials.json
#   3. Premier run : flow OAuth → gdrive_token.json
#   4. Créer dossiers Drive + noter les IDs
GDRIVE_ENABLED=true
GDRIVE_CREDENTIALS_PATH=/app/secrets/gdrive_credentials.json
GDRIVE_TOKEN_PATH=/app/secrets/gdrive_token.json
GDRIVE_FOLDER_ID_ARTIFACTS=<ID_DOSSIER_DRIVE>
GDRIVE_FOLDER_ID_USER_FILES=<ID_DOSSIER_DRIVE>
GDRIVE_FOLDER_ID_BRONZE=<ID_DOSSIER_DRIVE>

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# MLflow
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000  # si MinIO
MLFLOW_AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
MLFLOW_AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}

# -----------------------------------------------------------------------------
# TomTom Traffic Flow (Sprint VPS-6, 2026-06-11)
# -----------------------------------------------------------------------------
# Free tier : 2500 requêtes/jour (cf. https://developer.tomtom.com/).
# Sur le VPS, le DAG collect_tomtom_traffic tourne toutes les 15 min sur
# 12 tuiles Lyon = 1152 req/jour (bien sous le quota).
# Sans clé configurée → fallback cache 24h (et DashboardDataError en prod).
TOMTOM_API_KEY=<INSCRIVEZ_VOUS_SUR_DEVELOPER_TOMTOM_COM>

# -----------------------------------------------------------------------------
# API FastAPI
# -----------------------------------------------------------------------------
LYONFLOW_API_KEY=<REMPLACER_PAR_CLE_API_FORTE>
JWT_SECRET_KEY=<REMPLACER_PAR_SECRET_JWT>
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ALLOWED_ORIGINS=http://localhost:8501,http://localhost
# Pour dev : DISABLE_AUTH=true (NE JAMAIS en prod)
DISABLE_AUTH=false

# -----------------------------------------------------------------------------
# Airflow
# -----------------------------------------------------------------------------
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/airflow
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/airflow
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=<REMPLACER_PAR_MOT_DE_PASSE_ADMIN>
AIRFLOW_SECRET_KEY=<REMPLACER_PAR_CLE_SECRETE>
AIRFLOW_FERNET_KEY=<REMPLACER_PAR_CLE_FERNET>
AIRFLOW_UID=50000

# -----------------------------------------------------------------------------
# Personas — Auth dashboard (Sprint 8+ : démo simplifiée)
# -----------------------------------------------------------------------------
# Mode démo Jedha : mot de passe par défaut "demo2026" (hardcodé dans
# src/persona/auth.py : _DEMO_PASSWORD). L'env var ci-dessous override
# cette valeur si définie (pour les déploiements production).
#
# En production réelle (post-Jedha) :
# 1. Remplacer par des valeurs fortes (openssl rand -base64 16)
# 2. Hasher côté API (bcrypt déjà en place dans src/api/main.py)
# 3. Sortir du repo public : injecter au déploiement via vault/secret manager
# 4. Implémenter une rotation automatique
PERSONA_PRO_TCL_USERNAME=pro_tcl
PERSONA_PRO_TCL_PASSWORD=demo2026
PERSONA_ELU_USERNAME=elu
PERSONA_ELU_PASSWORD=demo2026

# -----------------------------------------------------------------------------
# Géolocalisation Lyon
# -----------------------------------------------------------------------------
LYON_LATITUDE=45.7640
LYON_LONGITUDE=4.8357

# -----------------------------------------------------------------------------
# Alertes
# -----------------------------------------------------------------------------
LYONFLOW_ALERT_WEBHOOK_URL=
LYONFLOW_ALERT_LOG=/app/logs/alerts.log

# -----------------------------------------------------------------------------
# Upload (file manager)
# -----------------------------------------------------------------------------
LYONFLOW_UPLOAD_DIR=/app/uploads

# -----------------------------------------------------------------------------
# ML hyperparameters (avec défauts)
# -----------------------------------------------------------------------------
SEQ_LEN=120
HORIZONS=6,12,36
HIDDEN_CHANNELS=128
WEIGHT_JAM=15
WEIGHT_SLOW=5
LYON_DEFAULT_SPEED=30.0

# -----------------------------------------------------------------------------
# Deploy (VPS) — utilisé par Makefile
# -----------------------------------------------------------------------------
VPS_HOST=ubuntu@<VOTRE_IP>
VPS_SSH_KEY=~/.ssh/lyonflow_deploy
VPS_DEPLOY_PATH=/opt/lyonflow

# --- Postgres data directory ---
# Local dev: laisser vide pour utiliser volume Docker default
# VPS prod: /mnt/postgres-data/pgdata (bind mount disque dédié sdb)
POSTGRES_DATA_DIR=
